# Base de datos PostgreSQL
# Necesitas una base de datos PostgreSQL. Puedes usar:
# - Neon (gratis): https://neon.tech
# - Supabase (gratis): https://supabase.com
# - Railway (gratis con límites): https://railway.app
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_base_datos

# Secreto para sesiones (genera una cadena larga y aleatoria)
SESSION_SECRET=una-cadena-muy-larga-y-secreta-aqui
